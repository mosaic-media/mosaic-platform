# Development image for the Mosaic Platform.
#
# Not a production build: source is bind-mounted and run with `go run`, so an
# edit is a restart rather than an image rebuild. A release image is a separate,
# later concern.
#
# It exists mainly for **ffmpeg**. Playback needs ffprobe to decide what a
# release actually is and ffmpeg to re-encode the streams a client cannot decode
# (ADR 0050); without them the Platform relays unprobed and a release with
# undecodable audio plays silently. In the image, that is a property of the
# environment rather than something each developer must remember to install.
FROM golang:1.25-bookworm

# ffmpeg brings ffprobe. curl is the healthcheck's only requirement.
RUN set -eux; \
    apt-get update; \
    apt-get install -y --no-install-recommends ffmpeg curl ca-certificates; \
    rm -rf /var/lib/apt/lists/*; \
    ffprobe -version | head -n 1

WORKDIR /src/platform

# buildvcs off because the bind-mounted source carries a .git the container has
# no business stat-ing, and it fails the build on ownership rather than
# degrading.
ENV GOFLAGS=-buildvcs=false

EXPOSE 8080 8081

CMD ["go", "run", "./cmd/mosaic-platform"]
